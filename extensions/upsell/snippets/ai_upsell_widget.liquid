{% comment %}AI-Powered Upsell Widget{% endcomment %}

{% assign customer_segment = 'anonymous' %}
{% if customer %}
  {% assign customer_segment = 'returning' %}
  {% if customer.orders_count == 0 %}{% assign customer_segment = 'first_time' %}{% endif %}
  {% if customer.tags contains 'subscriber' or customer.tags contains 'subscription' %}{% assign customer_segment = 'subscription' %}{% endif %}
  {% assign total_spent_cents = customer.total_spent | times: 100 | round %}
  {% if total_spent_cents >= 50000 %}{% assign customer_segment = 'high_ltv' %}{% endif %}
{% endif %}

{% unless request.page_type == 'cart' %}{% if product.id != blank %}
<script>(function(){if(!window.__AI_UPSELL_PREFETCH__){var uid='{% if customer %}customer_{{ customer.id }}{% endif %}';if(!uid){try{uid=localStorage.getItem('__ai_uid__')||'';if(!uid){uid='g_'+Math.random().toString(36).slice(2)+Date.now().toString(36);localStorage.setItem('__ai_uid__',uid);}}catch(_){}}window.__AI_UPSELL_USER_ID__=uid;window.__AI_UPSELL_SEGMENT__='{{ customer_segment }}';window.__AI_UPSELL_PREFETCH__=fetch('/apps/ai-upsell?id=gid://shopify/Product/{{ product.id }}'+(uid?'&userId='+encodeURIComponent(uid):'')+'&segment={{ customer_segment }}');}})();</script>
{% endif %}{% endunless %}
{% if request.page_type == 'cart' and cart.item_count > 0 %}
<script>(function(){if(!window.__AI_CART_PREFETCH__){var ids=[{% for item in cart.items %}"gid://shopify/Product/{{ item.product_id }}"{% unless forloop.last %},{% endunless %}{% endfor %}];var uid=window.__AI_UPSELL_USER_ID__||'';var seg=window.__AI_UPSELL_SEGMENT__||'{{ customer_segment }}';window.__AI_CART_PREFETCH__=fetch('/apps/ai-upsell/cart?ids='+encodeURIComponent(JSON.stringify(ids))+(uid?'&userId='+encodeURIComponent(uid):'')+('&segment='+encodeURIComponent(seg)));}})();</script>
<script>
(function(){
  var code = {{ cart.discount_code | json }};
  if (!code) {
    var attrCode = {{ cart.attributes.ai_discount_code | json }};
    if (attrCode) code = attrCode;
  }
  if (!code) {
    try {
      var stored = sessionStorage.getItem('__ai_volume_target__');
      if (stored) { var parsed = JSON.parse(stored); if (parsed && parsed.code) code = parsed.code; }
    } catch (_) {}
  }
  if (!code) return;
  try {
    var redirectKey = '__ai_cart_discount_redirect__';
    var last = parseInt(sessionStorage.getItem(redirectKey) || '0', 10);
    var now = Date.now();
    if (!{{ cart.discount_code | json }} && (!last || (now - last) > 15000)) {
      sessionStorage.setItem(redirectKey, String(now));
      var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
      if (root.charAt(0) !== '/') root = '/' + root;
      if (root.charAt(root.length - 1) !== '/') root += '/';
      var redir = root + 'cart';
      if (redir.charAt(0) !== '/') redir = '/' + redir;
      var url = root + 'discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent(redir);
      if (url) { window.location.href = url; return; }
    }
  } catch (_) {}
  function buildUrl(c, redirectPath){
    if (!c) return null;
    var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    if (root.charAt(0) !== '/') root = '/' + root;
    if (root.charAt(root.length - 1) !== '/') root += '/';
    if (redirectPath === 'checkout') {
      var checkout = root + 'checkout';
      var joiner = checkout.indexOf('?') === -1 ? '?' : '&';
      return checkout + joiner + 'discount=' + encodeURIComponent(c);
    }
    var clean = String(redirectPath || 'cart').replace(/^\/+/, '');
    var redir = root + clean;
    if (redir.charAt(0) !== '/') redir = '/' + redir;
    return root + 'discount/' + encodeURIComponent(c) + '?redirect=' + encodeURIComponent(redir);
  }
  var applying = false;
  async function applyDiscountAndCheckout(){
    if (applying) return;
    applying = true;
    try {
      await fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ discount: code })
      });
    } catch (_) {}
    try {
      // Wait briefly for cart to reflect discount
      for (var i = 0; i < 8; i++) {
        var r = await fetch('/cart.js');
        if (r && r.ok) {
          var cart = await r.json();
          if (cart && (cart.discount_code === code)) break;
        }
        await new Promise(function(res){ setTimeout(res, 150); });
      }
    } catch (_) {}
    var url = buildUrl(code, 'checkout');
    if (url) window.location.href = url;
  }
  function handleCheckout(e){
    var el = e.target.closest('a[href*="/checkout"], button[name="checkout"], input[name="checkout"]');
    if (!el) {
      var submit = e.target.closest('button[type="submit"], input[type="submit"], button:not([type])');
      if (submit) {
        var form = submit.closest('form');
        if (form && (form.action || '').indexOf('/checkout') !== -1) el = submit;
      }
    }
    if (!el) return;
    e.preventDefault();
    e.stopPropagation();
    if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
    applyDiscountAndCheckout();
  }
  document.addEventListener('click', handleCheckout, true);
  document.addEventListener('submit', function(e){
    var form = e.target;
    if (!form || form.tagName !== 'FORM') return;
    var action = form.action || form.getAttribute('action') || '';
    if (action.indexOf('/checkout') === -1) return;
    e.preventDefault();
    e.stopPropagation();
    applyDiscountAndCheckout();
  }, true);
})();
</script>
{% endif %}

{% assign upsell_settings = settings %}
{% if block and block.settings %}{% assign upsell_settings = block.settings %}{% endif %}

{% if request.page_type == 'product' %}
<div class="ai-upsell-widget" data-product-id="{{ product.id }}" data-shop="{{ shop.permanent_domain }}" data-source="{{ source | default: 'block' }}">
  <div class="ai-upsell-loading">
    <div class="ai-skeleton-header"></div>
    <div class="ai-skeleton-grid">
      <div class="ai-skeleton-card"><div class="ai-skeleton-image"></div><div class="ai-skeleton-info"><div class="ai-skeleton-text line-1"></div><div class="ai-skeleton-text line-2"></div><div class="ai-skeleton-button"></div></div></div>
      <div class="ai-skeleton-card hide-mobile"><div class="ai-skeleton-image"></div><div class="ai-skeleton-info"><div class="ai-skeleton-text line-1"></div><div class="ai-skeleton-text line-2"></div><div class="ai-skeleton-button"></div></div></div>
      <div class="ai-skeleton-card hide-tablet"><div class="ai-skeleton-image"></div><div class="ai-skeleton-info"><div class="ai-skeleton-text line-1"></div><div class="ai-skeleton-text line-2"></div><div class="ai-skeleton-button"></div></div></div>
      <div class="ai-skeleton-card hide-tablet"><div class="ai-skeleton-image"></div><div class="ai-skeleton-info"><div class="ai-skeleton-text line-1"></div><div class="ai-skeleton-text line-2"></div><div class="ai-skeleton-button"></div></div></div>
    </div>
  </div>
  <div class="ai-upsell-content" style="display:none;"></div>
</div>
{% endif %}

<div class="ai-secondary-widget" data-shop="{{ shop.permanent_domain }}" data-source="{{ source | default: 'block' }}" style="display:none;">
  <div class="ai-secondary-loading ai-skeleton-secondary-container" style="display:none;">
    <div class="ai-skeleton-secondary-header"></div>
    <div class="ai-skeleton-secondary-card">
      <div class="ai-skeleton-image-small"></div>
      <div class="ai-skeleton-details">
        <div class="ai-skeleton-text line-1"></div>
        <div class="ai-skeleton-text line-2"></div>
        <div class="ai-skeleton-button-small"></div>
      </div>
    </div>
  </div>
  <div class="ai-secondary-content"></div>
</div>

<script>
window.__AI_UPSELL_CONFIG__ = {
  productId: '{{ product.id }}',
  productTitle: {{ product.title | json }},
  productImage: {% if product.featured_image %}'{{ product.featured_image | img_url: "300x300" }}'{% else %}null{% endif %},
  productPrice: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | default: 0 }},
  productVariantId: '{{ product.selected_or_first_available_variant.id }}',
  productUrl: '{{ product.url }}',
  shopDomain: '{{ shop.permanent_domain }}',
  maxProducts: {{ upsell_settings.max_products | default: 4 }},
  heading: {{ upsell_settings.heading | json }},
  customerId: {% if customer %}'customer_{{ customer.id }}'{% else %}null{% endif %},
  customerName: {% if customer %}'{{ customer.first_name }} {{ customer.last_name }}'{% else %}null{% endif %},
  customerSegment: '{{ customer_segment }}',
  isCartPage: {% if request.page_type == 'cart' %}true{% else %}false{% endif %},
  isProductPage: {% if request.page_type == 'product' %}true{% else %}false{% endif %}
};
</script>

<style>
:root {
  --ai-mt: {{ upsell_settings.margin_top | default: 0 }}px;
  --ai-mb: {{ upsell_settings.margin_bottom | default: 0 }}px;
  --ai-pd: {{ upsell_settings.padding | default: 0 }}px;
  --ai-bg: {{ upsell_settings.background_color | default: 'transparent' }};
  --ai-br: {{ upsell_settings.border_radius | default: 0 }}px;
  --ai-text: {{ upsell_settings.text_color | default: '#333333' }};
  --ai-primary: {{ upsell_settings.primary_color | default: '#008060' }};
  --ai-heading-size: {{ upsell_settings.heading_size | default: 24 }}px;
  --ai-heading-color: {{ upsell_settings.heading_color | default: '#333333' }};
  --ai-grid-gap: {{ upsell_settings.grid_gap | default: 20 }}px;
  --ai-card-bg: {{ upsell_settings.card_background | default: '#ffffff' }};
  --ai-card-radius: {{ upsell_settings.card_border_radius | default: 8 }}px;
  --ai-hover-lift: {{ upsell_settings.hover_lift | default: 4 }}px;
  --ai-hover-shadow: {{ upsell_settings.hover_shadow | default: '0 8px 24px rgba(0,0,0,0.12)' }};
  --ai-card-padding: {{ upsell_settings.card_padding | default: 16 }}px;
  --ai-title-size: {{ upsell_settings.product_title_size | default: 14 }}px;
  --ai-price-size: {{ upsell_settings.price_size | default: 14 }}px;
  --ai-price-color: {{ upsell_settings.price_color | default: '#333333' }};
  --ai-reason-size: {{ upsell_settings.reason_size | default: 13 }}px;
  --ai-reason-color: {{ upsell_settings.reason_color | default: '#666666' }};
  --ai-add-bg: {{ upsell_settings.add_to_cart_bg | default: '#008060' }};
  --ai-add-text: {{ upsell_settings.add_to_cart_text | default: '#ffffff' }};
  --ai-add-hover-bg: {{ upsell_settings.add_to_cart_hover_bg | default: '#004c3f' }};
  --ai-add-hover-text: {{ upsell_settings.add_to_cart_hover_text | default: '#ffffff' }};
  --ai-add-disabled-bg: {{ upsell_settings.add_to_cart_disabled_bg | default: '#cccccc' }};
  --ai-add-disabled-text: {{ upsell_settings.add_to_cart_disabled_text | default: '#999999' }};
  --ai-button-color: {{ upsell_settings.button_color | default: '#008060' }};
}
</style>

{{ 'ai-upsell.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ai-upsell.js' | asset_url }}" defer></script>
